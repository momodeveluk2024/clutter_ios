<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration for NutriMate.
  - Production: only HTTPS is allowed (usesCleartextTraffic=false in manifest).
  - Debug/Profile: this config allows cleartext to localhost and 10.0.2.2
    for local development only.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext only for local development servers -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
